# ===========================================
# Slice 2 — test-only env overrides (committed scaffold)
# Copy to .env.test.local and adjust if needed.
# ===========================================
#
# Real secrets (HUBSPOT_CLIENT_SECRET, LLM_API_KEY, EXA_API_KEY, ROOT_KEK,
# HUBSPOT_PRIVATE_APP_TOKEN) live in repo-root .env — see .env.example.
#
# vitest.setup.ts loads .env first, then .env.test.local with
# `override: true`. The values below are intentionally test-only and
# MUST NOT appear in any production environment.

NODE_ENV=test

# Enables the x-test-portal-id auth bypass for tests.
# apps/api/src/middleware/auth.ts gates the bypass on this AND
# NODE_ENV === "test" — defense in depth.
ALLOW_TEST_AUTH=true

# Test portal pinned (HubSpot CLI default account).
HUBSPOT_TEST_PORTAL_ID=147062576
