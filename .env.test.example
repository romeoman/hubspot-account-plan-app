# ===========================================
# Slice 2 test/dev env scaffold (committed)
# Copy to .env.test.local and fill real values.
# Real values must NEVER be committed.
# ===========================================

# --- Database ---
# Local dev: Docker Postgres. Production tenants set DATABASE_URL to their own
# managed Postgres (Supabase / Neon / RDS). The product is config-driven —
# docker-compose.yml is a developer-machine convenience only, NOT a runtime
# requirement.
DATABASE_URL=postgresql://hap:hap_local_dev@localhost:5433/hap_dev

# --- HubSpot signed-request auth (Slice 2 Step 4) ---
# Provided by `hs project upload` after the developer app is provisioned on
# the dev portal (man-digital-dev-account-oct, portal 147062576). Visible in
# HubSpot UI: Developer → Projects → hap-signal-workspace → Auth tab.
HUBSPOT_CLIENT_SECRET=replace_with_value_from_hubspot_ui

# Backend uses one of the following for server-to-HubSpot calls (Step 9
# enrichment + Step 14 seed). Pick ONE auth model — Slice 2 uses static
# (private app); Slice 3 may add OAuth.
HUBSPOT_PRIVATE_APP_TOKEN=replace_with_value_from_hubspot_private_app_settings
# Alternative (OAuth, Slice 3+):
# HUBSPOT_OAUTH_REFRESH_TOKEN=
# HUBSPOT_CLIENT_ID=

# Test portal pinned by HubSpot CLI default account; this var lets the seed
# script (Step 14) target it without reading ~/hubspot.config.yml.
HUBSPOT_TEST_PORTAL_ID=147062576

# --- Test-only auth bypass (Slice 2 Step 4) ---
# Enables the x-test-portal-id header bypass. The middleware refuses it
# unless this is exactly "true" — set ONLY in test/dev environments.
ALLOW_TEST_AUTH=true

# --- Encryption (Slice 2 Step 3) ---
# 32 random bytes, base64. Generate with: openssl rand -base64 32
# This is the master KEK. Tenant KEKs are HKDF-derived per request and never
# leave the api process.
ROOT_KEK=replace_with_openssl_rand_base64_32

# --- LLM cassette recording (Slice 2 Step 8 — test-time only) ---
# These are NOT runtime keys — runtime keys live per-tenant in
# llm_provider_config encrypted with AES-256-GCM. These keys exist only to
# record cassettes during adapter test authoring. Once cassettes are
# committed, CI replays from disk and never needs live keys.
OPENAI_API_KEY=replace_with_real_openai_key_for_cassette_recording
ANTHROPIC_API_KEY=
# Slice 3: record live cassettes when keys available
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- Signal cassette recording (Slice 2 Step 9 — test-time only) ---
# Same rule: real per-tenant keys live in provider_config encrypted at rest.
EXA_API_KEY=replace_with_real_exa_key_for_cassette_recording

# --- Hono / Node ---
NODE_ENV=test
PORT=3001
